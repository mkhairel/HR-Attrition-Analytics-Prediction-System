<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="hr_employee_data.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="5684"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="hr_employee_data" custom_title="0" dock_id="1" table="4,16:mainhr_employee_data"/><dock_state state="000000ff00000000fd0000000100000002000002f200000280fc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000000002f20000012d00ffffff000002580000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="hr_employee_data" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort><column index="0" mode="0"/></sort><column_widths><column index="1" value="29"/><column index="2" value="55"/><column index="3" value="91"/><column index="4" value="62"/><column index="5" value="75"/><column index="6" value="117"/><column index="7" value="63"/><column index="8" value="90"/><column index="9" value="95"/><column index="10" value="106"/><column index="11" value="144"/><column index="12" value="48"/><column index="13" value="71"/><column index="14" value="98"/><column index="15" value="57"/><column index="16" value="52"/><column index="17" value="93"/><column index="18" value="83"/><column index="19" value="95"/><column index="20" value="79"/><column index="21" value="138"/><column index="22" value="49"/><column index="23" value="62"/><column index="24" value="110"/><column index="25" value="116"/><column index="26" value="143"/><column index="27" value="91"/><column index="28" value="105"/><column index="29" value="114"/><column index="30" value="135"/><column index="31" value="102"/><column index="32" value="103"/><column index="33" value="118"/><column index="34" value="150"/><column index="35" value="138"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">CREATE TABLE hr_employee_data (
    Age INT,
    Attrition VARCHAR(10),
    BusinessTravel VARCHAR(30),
    DailyRate INT,
    Department VARCHAR(50),
    DistanceFromHome INT,
    Education INT,
    EducationField VARCHAR(50),
    EmployeeCount INT,
    EmployeeNumber INT PRIMARY KEY,
    EnvironmentSatisfaction INT,
    Gender VARCHAR(10),
    HourlyRate INT,
    JobInvolvement INT,
    JobLevel INT,
    JobRole VARCHAR(50),
    JobSatisfaction INT,
    MaritalStatus VARCHAR(20),
    MonthlyIncome INT,
    MonthlyRate INT,
    NumCompaniesWorked INT,
    IsOver18 VARCHAR(5),  
    OverTime VARCHAR(5),
    PercentSalaryHike INT,
    PerformanceRating INT,
    RelationshipSatisfaction INT,
    StandardHours INT,
    StockOptionLevel INT,
    TotalWorkingYears INT,
    TrainingTimesLastYear INT,
    WorkLifeBalance INT,
    YearsAtCompany INT,
    YearsInCurrentRole INT,
    YearsSinceLastPromotion INT,
    YearsWithCurrManager INT
);
PRAGMA table_info(hr_employee_data);

--Total Employee
SELECT COUNT(*) AS total_employees
FROM hr_employee_data;

--Attrition Count
SELECT Attrition,
       COUNT(*) AS employee_count
FROM hr_employee_data
GROUP BY Attrition;

--Arritation Rate
SELECT 
    ROUND(
        SUM(CASE WHEN Attrition = 'Yes' THEN 1 ELSE 0 END) * 100.0 
        / COUNT(*),
    2) AS attrition_rate
FROM hr_employee_data;

--Arritation by Department
SELECT Department,
       COUNT(*) AS total_attrition
FROM hr_employee_data
WHERE Attrition = 'Yes'
GROUP BY Department
ORDER BY total_attrition DESC;

--Overtime vs Attrition
SELECT OverTime,
       Attrition,
       COUNT(*) AS total_employees
FROM hr_employee_data
GROUP BY OverTime, Attrition;

--Avarage Salary by Attrition
SELECT Attrition,
       ROUND(AVG(MonthlyIncome),2) AS avg_salary
FROM hr_employee_data
GROUP BY Attrition;

--Top Job with Attrition
SELECT JobRole,
       COUNT(*) AS attrition_count
FROM hr_employee_data
WHERE Attrition = 'Yes'
GROUP BY JobRole
ORDER BY attrition_count DESC;

--Avarage Years at Company
SELECT Attrition,
       ROUND(AVG(YearsAtCompany),2) AS avg_years
FROM hr_employee_data
GROUP BY Attrition;

--Job Satisfaction Analysis
SELECT JobSatisfaction,
       COUNT(*) AS attrition_count
FROM hr_employee_data
WHERE Attrition = 'Yes'
GROUP BY JobSatisfaction
ORDER BY attrition_count DESC;

--Gender Attrition Analysis
SELECT Gender,
       Attrition,
       COUNT(*) AS total
FROM hr_employee_data
GROUP BY Gender, Attrition;

--Worklife Balance
SELECT WorkLifeBalance,
       COUNT(*) AS attrition_count
FROM hr_employee_data
WHERE Attrition = 'Yes'
GROUP BY WorkLifeBalance
ORDER BY attrition_count DESC;
</sql><current_tab id="0"/></tab_sql></sqlb_project>
